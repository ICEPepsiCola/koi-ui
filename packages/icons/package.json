{
  "name": "@koi-ui/icons",
  "version": "1.2.0",
  "description": "Vendored Heroicons React icons for Koi UI",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./16/solid": {
      "types": "./src/16/solid/index.ts",
      "import": "./src/16/solid/index.ts"
    },
    "./20/solid": {
      "types": "./src/20/solid/index.ts",
      "import": "./src/20/solid/index.ts"
    },
    "./24/outline": {
      "types": "./src/24/outline/index.ts",
      "import": "./src/24/outline/index.ts"
    },
    "./24/solid": {
      "types": "./src/24/solid/index.ts",
      "import": "./src/24/solid/index.ts"
    }
  },
  "types": "./src/index.ts",
  "files": [
    "dist",
    "LICENSE.heroicons",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./16/solid": {
        "types": "./dist/16/solid/index.d.ts",
        "import": "./dist/16/solid/index.js"
      },
      "./20/solid": {
        "types": "./dist/20/solid/index.d.ts",
        "import": "./dist/20/solid/index.js"
      },
      "./24/outline": {
        "types": "./dist/24/outline/index.d.ts",
        "import": "./dist/24/outline/index.js"
      },
      "./24/solid": {
        "types": "./dist/24/solid/index.d.ts",
        "import": "./dist/24/solid/index.js"
      }
    },
    "types": "./dist/index.d.ts"
  },
  "scripts": {
    "build": "rslib",
    "dev": "rslib --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@rsbuild/plugin-react": "^2.1.0",
    "@rslib/core": "^0.23.2",
    "@types/react": "^19.2.17",
    "react": "^19.2.7",
    "typescript": "^6.0.3"
  }
}
